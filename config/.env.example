# GMP合规性审计系统配置文件

# ============================================================
# LLM模型配置 (至少配置一个提供商)
# 所有 OpenAI 兼容提供商的 BASE_URL 应包含版本路径 (如 /v1)
# ============================================================

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 通义千问 (Qwen)
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 智谱 GLM
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# SiliconFlow (支持多种开源模型)
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenRouter (聚合多家模型)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Mimo / MiniMax
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://api.minimax.chat/v1

# ============================================================
# 飞书配置 (用于登录和通知)
# ============================================================
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_REDIRECT_URI=http://localhost:8000/api/auth/feishu/callback
FEISHU_WEBHOOK_URL=your_feishu_webhook_url

# ============================================================
# JWT配置 (重要: 生产环境必须修改!)
# ============================================================
# 请使用随机生成的密钥, 例如: openssl rand -hex 32
JWT_SECRET_KEY=your-secure-random-key-here

# ============================================================
# 应用配置
# ============================================================
LOG_LEVEL=INFO
MAX_CONCURRENT_TASKS=5
DOCUMENT_PROCESS_TIMEOUT=300
LLM_REQUEST_TIMEOUT=120
