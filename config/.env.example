# AuditBee - GMP 合规性审计系统配置文件

# ============================================================
# LLM模型配置 (至少配置一个提供商)
# 所有 OpenAI 兼容提供商的 BASE_URL 应包含版本路径 (如 /v1)
# ============================================================

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=your_deepseek_model_here

# 通义千问 (Qwen)
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=your_qwen_model_here

# 智谱 GLM
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=your_glm_model_here

# SiliconFlow (支持多种开源模型)
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=your_siliconflow_model_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=your_openai_model_here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=your_anthropic_model_here

# OpenRouter (聚合多家模型)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=your_openrouter_model_here

# Mimo / MiniMax
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=your_mimo_model_here

# Agent 默认 LLM 提供商 (可选值: mimo, deepseek, qwen, glm, siliconflow, openai, anthropic, openrouter)
AGENT_LLM_PROVIDER=mimo

# Embedding 模型路径 (用于 LightRAG 知识图谱，默认为项目根目录下的 model/ 文件夹)
# EMBEDDING_MODEL_PATH=D:\learn\claudecode\gmpaudit\model

# ============================================================
# 飞书配置 (Webhook Bot 群通知，可选)
# 在飞书群设置中添加自定义机器人，复制 Webhook 地址填入下方
# ============================================================
FEISHU_WEBHOOK_URL=your_feishu_webhook_url
FEISHU_WEBHOOK_SECRET=

# ============================================================
# 应用配置
# ============================================================
TEMPERATURE=0.7
LOG_LEVEL=INFO
MAX_CONCURRENT_TASKS=5
DOCUMENT_PROCESS_TIMEOUT=300
LLM_REQUEST_TIMEOUT=120
CORS_ORIGINS=*
