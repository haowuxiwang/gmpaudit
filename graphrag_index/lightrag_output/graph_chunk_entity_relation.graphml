<graph edgedefault="undirected"><node id="质量保证体系">
  <data key="d0">质量保证体系</data>
  <data key="d1">concept</data>
  <data key="d2">质量保证体系是企业建立并实施的体系，旨在确保药品按照批准的工艺规程和质量标准进行生产和控制。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305072</data>
  <data key="d6"></data>
</node>
<node id="质量控制">
  <data key="d0">质量控制</data>
  <data key="d1">concept</data>
  <data key="d2">质量控制包括相应的组织机构、文件系统以及取样、检验等活动，旨在确保物料或产品在放行前完成必要的检验，确认其质量符合要求。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305072</data>
  <data key="d6"></data>
</node>
<node id="企业">
  <data key="d0">企业</data>
  <data key="d1">organization</data>
  <data key="d2">企业是需要建立并实施质量保证体系、配备资源、建立各种管理程序并定期自检的组织。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305072</data>
  <data key="d6"></data>
</node>
<node id="高层管理人员">
  <data key="d0">高层管理人员</data>
  <data key="d1">person</data>
  <data key="d2">高层管理人员是企业的领导层，负责确保实现质量目标所必需的资源。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305072</data>
  <data key="d6"></data>
</node>
<node id="质量管理部门">
  <data key="d0">质量管理部门</data>
  <data key="d1">organization</data>
  <data key="d2">质量管理部门是企业内负责参与所有与质量有关活动的部门。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305072</data>
  <data key="d6"></data>
</node>
<node id="偏差处理程序">
  <data key="d0">偏差处理程序</data>
  <data key="d1">method</data>
  <data key="d2">偏差处理程序是企业建立的程序，用于记录、说明任何偏差，并对重大偏差进行调查，调查及结论需形成文件。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305072</data>
  <data key="d6"></data>
</node>
<node id="变更控制系统">
  <data key="d0">变更控制系统</data>
  <data key="d1">method</data>
  <data key="d2">变更控制系统是企业建立的系统，用于对可能影响产品质量的变更进行评估、批准和管理，并在实施后进行评价。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305072</data>
  <data key="d6"></data>
</node>
<node id="CAPA系统">
  <data key="d0">CAPA系统</data>
  <data key="d1">method</data>
  <data key="d2">CAPA系统(纠正和预防措施系统)是企业建立的系统，其纠正措施用于消除已发现的不符合项的原因，预防措施用于消除潜在不符合项的原因。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305072</data>
  <data key="d6"></data>
</node>
<node id="供应商评估和批准程序">
  <data key="d0">供应商评估和批准程序</data>
  <data key="d1">method</data>
  <data key="d2">供应商评估和批准程序是企业建立的程序，旨在确保原材料从认可的供应商处采购。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305074</data>
  <data key="d6"></data>
</node>
<node id="自检">
  <data key="d0">自检</data>
  <data key="d1">method</data>
  <data key="d2">自检是企业定期进行的活动，用于监控GMP的实施情况，并提出必要的纠正和预防措施。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305074</data>
  <data key="d6"></data>
</node>
<node id="药品">
  <data key="d0">药品</data>
  <data key="d1">artifact</data>
  <data key="d2">药品是按照批准的工艺规程和质量标准进行生产和控制的产品。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305074</data>
  <data key="d6"></data>
</node>
<node id="生产工艺">
  <data key="d0">生产工艺</data>
  <data key="d1">method</data>
  <data key="d2">生产工艺是制定并经过验证的生产过程，旨在可持续稳定地生产出符合要求的产品。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305074</data>
  <data key="d6"></data>
</node>
<node id="中文说明书">
  <data key="d0">中文说明书</data>
  <data key="d1">content</data>
  <data key="d2">中文说明书是清晰准确的产品使用说明。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305075</data>
  <data key="d6"></data>
</node>
<node id="操作人员">
  <data key="d0">操作人员</data>
  <data key="d1">person</data>
  <data key="d2">操作人员是经过培训的生产操作人员。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305075</data>
  <data key="d6"></data>
</node>
<node id="记录">
  <data key="d0">记录</data>
  <data key="d1">data</data>
  <data key="d2">记录是生产全过程的手工或仪器记录，用于追溯批产品的完整生产历史。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305075</data>
  <data key="d6"></data>
</node>
<node id="批产品">
  <data key="d0">批产品</data>
  <data key="d1">data</data>
  <data key="d2">批产品是能够追溯完整生产历史的产品批次。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305075</data>
  <data key="d6"></data>
</node>
<node id="投诉">
  <data key="d0">投诉</data>
  <data key="d1">data</data>
  <data key="d2">投诉是针对上市产品提出的，企业需要审查其原因并采取措施。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305076</data>
  <data key="d6"></data>
</node>
<node id="原材料">
  <data key="d0">原材料</data>
  <data key="d1">data</data>
  <data key="d2">原材料是从认可供应商处采购的生产物料。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305076</data>
  <data key="d6"></data>
</node>
<node id="中间产品">
  <data key="d0">中间产品</data>
  <data key="d1">data</data>
  <data key="d2">中间产品是生产过程中的中间物料。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305077</data>
  <data key="d6"></data>
</node>
<node id="成品">
  <data key="d0">成品</data>
  <data key="d1">data</data>
  <data key="d2">成品是完成生产的最终产品。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305077</data>
  <data key="d6"></data>
</node>
<node id="中国GMP(2010年修订版)">
  <data key="d0">中国GMP(2010年修订版)</data>
  <data key="d1">artifact</data>
  <data key="d2">中国GMP(2010年修订版)是中国药品生产质量管理规范的法规文件，规定了企业质量管理体系的基本要求。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305078</data>
  <data key="d6"></data>
</node>
<node id="召回系统">
  <data key="d0">召回系统</data>
  <data key="d1">method</data>
  <data key="d2">召回系统是企业建立的系统，能够召回任何一批已发运的产品，以降低质量风险。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305078</data>
  <data key="d6"></data>
</node>
<node id="质量目标">
  <data key="d0">质量目标</data>
  <data key="d1">concept</data>
  <data key="d2">质量目标是企业需要实现的目标，高层管理人员应当确保实现质量目标所必需的资源。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305078</data>
  <data key="d6"></data>
</node>
<node id="质量标准">
  <data key="d0">质量标准</data>
  <data key="d1">concept</data>
  <data key="d2">质量标准是药品生产和控制必须遵循的标准，确保药品质量符合要求。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305078</data>
  <data key="d6"></data>
</node>
<node id="工艺规程">
  <data key="d0">工艺规程</data>
  <data key="d1">content</data>
  <data key="d2">工艺规程是经批准的药品生产工艺文件，药品应按照批准的工艺规程进行生产和控制。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305079</data>
  <data key="d6"></data>
</node>
<node id="偏差">
  <data key="d0">偏差</data>
  <data key="d1">concept</data>
  <data key="d2">偏差是生产过程中出现的偏离规定程序的情况，任何偏差都应当记录并说明，重大偏差应当进行调查。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305080</data>
  <data key="d6"></data>
</node>
<node id="变更">
  <data key="d0">变更</data>
  <data key="d1">concept</data>
  <data key="d2">变更是可能影响产品质量的改变，实施前应当经过评估、批准，实施后应当进行评价。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305080</data>
  <data key="d6"></data>
</node>
<node id="验证">
  <data key="d0">验证</data>
  <data key="d1">method</data>
  <data key="d2">验证是对生产工艺及其重大变更进行确认的活动，确保其可持续稳定地生产出符合要求的产品。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305081</data>
  <data key="d6"></data>
</node>
<node id="培训">
  <data key="d0">培训</data>
  <data key="d1">method</data>
  <data key="d2">培训是操作人员必须接受的教育活动，确保其具备正确执行生产操作的能力。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305081</data>
  <data key="d6"></data>
</node>
<node id="资源">
  <data key="d0">资源</data>
  <data key="d1">concept</data>
  <data key="d2">资源是实现质量目标所必需的人员、厂房、设施和设备等，由高层管理人员确保配备。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305082</data>
  <data key="d6"></data>
</node>
<node id="GMP">
  <data key="d0">GMP</data>
  <data key="d1">concept</data>
  <data key="d2">GMP(Good Manufacturing Practice)是药品生产质量管理规范，是企业实施质量管理的基本框架。&lt;SEP&gt;Good Manufacturing Practice (GMP) is a set of requirements that must be contained within the Pharmaceutical Quality System.</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c&lt;SEP&gt;chunk-f5b35ed187d30c5517f660031690eb31</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305346</data>
  <data key="d6"></data>
</node>
<node id="质量风险">
  <data key="d0">质量风险</data>
  <data key="d1">concept</data>
  <data key="d2">质量风险是产品在发运和使用过程中可能面临的质量隐患，企业应当最大限度地降低质量风险。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305082</data>
  <data key="d6"></data>
</node>
<node id="不符合项">
  <data key="d0">不符合项</data>
  <data key="d1">concept</data>
  <data key="d2">不符合项是质量管理体系中发现的问题，包括已发现的不符合项和潜在的不符合项，CAPA系统用于消除其原因。</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d4">unknown_source</data>
