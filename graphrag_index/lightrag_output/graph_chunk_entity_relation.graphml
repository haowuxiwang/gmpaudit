  <data key="d4">unknown_source</data>
  <data key="d5">1778305090</data>
  <data key="d6"></data>
</node>
<node id="生产步骤">
  <data key="d0">生产步骤</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d2">质量保证体系确保按照要求完成了生产过程中各步骤。</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305091</data>
  <data key="d6"></data>
</node>
<node id="产品">
  <data key="d0">产品</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d2">质量控制确保产品在放行前完成必要的检验。</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305091</data>
  <data key="d6"></data>
</node>
<node id="调查">
  <data key="d0">调查</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d2">偏差均经过调查。</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305094</data>
  <data key="d6"></data>
</node>
<node id="重大偏差">
  <data key="d0">重大偏差</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d2">偏差处理程序对重大偏差进行调查。</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305096</data>
  <data key="d6"></data>
</node>
<node id="产品发运">
  <data key="d0">产品发运</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d2">产品的发运能够最大限度地降低质量风险。</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305097</data>
  <data key="d6"></data>
</node>
<node id="评估批准">
  <data key="d0">评估批准</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d2">变更实施前应当经过评估、批准。</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305097</data>
  <data key="d6"></data>
</node>
<node id="评价">
  <data key="d0">评价</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d2">变更实施后应当进行评价，确认变更达到了预期目标。</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305098</data>
  <data key="d6"></data>
</node>
<node id="GMP实施">
  <data key="d0">GMP实施</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d2">自检用于监控GMP的实施情况。</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305100</data>
  <data key="d6"></data>
</node>
<node id="纠正预防措施">
  <data key="d0">纠正预防措施</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d2">自检提出必要的纠正和预防措施。</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305101</data>
  <data key="d6"></data>
</node>
<node id="已发现不符合项">
  <data key="d0">已发现不符合项</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d2">CAPA系统的纠正措施应当消除已发现的不符合项的原因。</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305102</data>
  <data key="d6"></data>
</node>
<node id="潜在不符合项">
  <data key="d0">潜在不符合项</data>
  <data key="d3">chunk-2949dafb1d421a228f88f13753dc4e0c</data>
  <data key="d2">CAPA系统的预防措施应当消除潜在不符合项的原因。</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305105</data>
  <data key="d6"></data>
</node>
<node id="China GMP (2010 Revision) Chapter 8">
  <data key="d0">China GMP (2010 Revision) Chapter 8</data>
  <data key="d1">content</data>
  <data key="d2">Chapter 8 of the China GMP (2010 Revision) details the requirements for document management in pharmaceutical manufacturing.</data>
  <data key="d3">chunk-afbbb826e07cbd2aa694c0ded935e688</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305179</data>
  <data key="d6"></data>
</node>
<node id="Document Management System">
  <data key="d0">Document Management System</data>
  <data key="d1">artifact</data>
  <data key="d2">A system that enterprises must establish to manage the drafting, revision, review, approval, distribution, replacement, and withdrawal of documents.</data>
  <data key="d3">chunk-afbbb826e07cbd2aa694c0ded935e688</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305179</data>
  <data key="d6"></data>
</node>
<node id="Document">
  <data key="d0">Document</data>
  <data key="d1">content</data>
  <data key="d2">A fundamental element of the quality assurance system, covering quality standards, production formulas, process procedures, operating procedures, and records.</data>
  <data key="d3">chunk-afbbb826e07cbd2aa694c0ded935e688</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305179</data>
  <data key="d6"></data>
</node>
<node id="Batch Production Record">
  <data key="d0">Batch Production Record</data>
  <data key="d1">content</data>
  <data key="d2">A record created based on the approved current production formula and process procedure, designed to avoid transcription errors, and containing specific production details.</data>
  <data key="d3">chunk-afbbb826e07cbd2aa694c0ded935e688</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305180</data>
  <data key="d6"></data>
</node>
<node id="Batch Inspection Record">
  <data key="d0">Batch Inspection Record</data>
  <data key="d1">content</data>
  <data key="d2">A record that must accompany each batch of drug, which must be true and complete, reflecting the entire production process.</data>
  <data key="d3">chunk-afbbb826e07cbd2aa694c0ded935e688</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305180</data>
  <data key="d6"></data>
</node>
<node id="Production Department">
  <data key="d0">Production Department</data>
  <data key="d1">organization</data>
  <data key="d2">The department responsible for filling out batch production records.&lt;SEP&gt;The Production Department is an organizational unit from which the Quality Control Department must maintain independence.</data>
  <data key="d3">chunk-afbbb826e07cbd2aa694c0ded935e688&lt;SEP&gt;chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305255</data>
  <data key="d6"></data>
</node>
<node id="Quality Control Department">
  <data key="d0">Quality Control Department</data>
  <data key="d1">organization</data>
  <data key="d2">The department responsible for reviewing batch records.&lt;SEP&gt;The Quality Control Department is an organizational unit that must be independent of the Production Department, responsible for setting internal standards, sampling, testing, stability evaluation, clean room monitoring, and laboratory management.</data>
  <data key="d3">chunk-afbbb826e07cbd2aa694c0ded935e688&lt;SEP&gt;chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305255</data>
  <data key="d6"></data>
</node>
<node id="Data">
  <data key="d0">Data</data>
  <data key="d1">data</data>
  <data key="d2">Information that must be accurate and complete; changes to data must be justified, with the original data kept readable and the changer and date recorded.</data>
  <data key="d3">chunk-afbbb826e07cbd2aa694c0ded935e688</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305181</data>
  <data key="d6"></data>
</node>
<node id="Electronic Record">
  <data key="d0">Electronic Record</data>
  <data key="d1">content</data>
  <data key="d2">A type of record that must meet specific requirements, including access control, change logging, regular backups, and authorization for data entry or modification.</data>
  <data key="d3">chunk-afbbb826e07cbd2aa694c0ded935e688</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305182</data>
  <data key="d6"></data>
</node>
<node id="Drug">
  <data key="d0">Drug</data>
  <data key="d1">artifact</data>
  <data key="d2">A pharmaceutical product for which batch production and inspection records must be maintained.</data>
  <data key="d3">chunk-afbbb826e07cbd2aa694c0ded935e688</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305182</data>
  <data key="d6"></data>
</node>
<node id="Authorized Personnel">
  <data key="d0">Authorized Personnel</data>
  <data key="d1">person</data>
  <data key="d2">Individuals who are permitted to enter or modify data in electronic records.</data>
  <data key="d3">chunk-afbbb826e07cbd2aa694c0ded935e688</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305182</data>
  <data key="d6"></data>
</node>
<node id="Shelf Life">
  <data key="d0">Shelf Life</data>
  <data key="d1">concept</data>
  <data key="d2">The period during which a drug is considered usable; batch records must be kept for at least one year after its expiration, or for at least five years if no shelf life is specified.</data>
  <data key="d3">chunk-afbbb826e07cbd2aa694c0ded935e688</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305183</data>
  <data key="d6"></data>
</node>
<node id="Quality Assurance System">
  <data key="d0">Quality Assurance System</data>
  <data key="d1">concept</data>
  <data key="d2">The overarching system for ensuring pharmaceutical quality, for which documents are described as a fundamental element.</data>
  <data key="d3">chunk-afbbb826e07cbd2aa694c0ded935e688</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305183</data>
  <data key="d6"></data>
</node>
<node id="Production Formula">
  <data key="d0">Production Formula</data>
  <data key="d1">method</data>
  <data key="d2">The approved formula for drug production, which serves as the basis for creating batch production records.</data>
  <data key="d3">chunk-afbbb826e07cbd2aa694c0ded935e688</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305183</data>
  <data key="d6"></data>
</node>
<node id="Process Procedure">
  <data key="d0">Process Procedure</data>
  <data key="d1">method</data>
  <data key="d2">The approved manufacturing process steps, which serve as the basis for creating batch production records.</data>
  <data key="d3">chunk-afbbb826e07cbd2aa694c0ded935e688</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305184</data>
  <data key="d6"></data>
</node>
<node id="Key Process Parameters">
  <data key="d0">Key Process Parameters</data>
  <data key="d1">data</data>
  <data key="d2">Critical manufacturing parameters whose actual values must be recorded in the batch production record.</data>
  <data key="d3">chunk-afbbb826e07cbd2aa694c0ded935e688</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305185</data>
  <data key="d6"></data>
</node>
<node id="Material Balance Calculation">
  <data key="d0">Material Balance Calculation</data>
  <data key="d1">method</data>
  <data key="d2">A calculation that must be included in the batch production record to account for material usage and yield.</data>
  <data key="d3">chunk-afbbb826e07cbd2aa694c0ded935e688</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305185</data>
  <data key="d6"></data>
</node>
<node id="Deviation Investigation Record">
  <data key="d0">Deviation Investigation Record</data>
  <data key="d1">content</data>
  <data key="d2">A record of deviations from standard procedures and their investigation, which must be included in the batch production record.</data>
  <data key="d3">chunk-afbbb826e07cbd2aa694c0ded935e688</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305186</data>
  <data key="d6"></data>
</node>
<node id="China GMP (2010 Revision)">
  <data key="d0">China GMP (2010 Revision)</data>
  <data key="d1">concept</data>
  <data key="d2">China GMP (2010 Revision) is a national regulatory framework for pharmaceutical Good Manufacturing Practice in China, with Chapter 10 specifically addressing quality control and quality assurance requirements.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305255</data>
  <data key="d6"></data>
</node>
<node id="Quality Control">
  <data key="d0">Quality Control</data>
  <data key="d1">concept</data>
  <data key="d2">Quality Control refers to the systematic activities including sampling, testing, stability evaluation, and monitoring of materials, intermediates, and finished products to ensure they meet established standards.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305255</data>
  <data key="d6"></data>
</node>
<node id="Quality Assurance">
  <data key="d0">Quality Assurance</data>
  <data key="d1">concept</data>
  <data key="d2">Quality Assurance is a broad concept encompassing all planned and systematic activities implemented within the quality system to ensure that products meet quality requirements, as covered in Chapter 10 of China GMP.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305255</data>
  <data key="d6"></data>
</node>
<node id="Deviation Handling Procedure">
  <data key="d0">Deviation Handling Procedure</data>
  <data key="d1">method</data>
  <data key="d2">The Deviation Handling Procedure is a formal process that includes deviation reporting and recording, investigation and evaluation, classification, corrective and preventive action development and implementation, and deviation closure.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305256</data>
  <data key="d6"></data>
</node>
<node id="Change Control Procedure">
  <data key="d0">Change Control Procedure</data>
  <data key="d1">method</data>
  <data key="d2">The Change Control Procedure is a formal process that includes change application and approval, classification and evaluation, implementation and verification, and change closure.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305256</data>
  <data key="d6"></data>
</node>
<node id="CAPA Procedure">
  <data key="d0">CAPA Procedure</data>
  <data key="d1">method</data>
  <data key="d2">The Corrective and Preventive Actions (CAPA) Procedure is a formal process that includes non-conformance reporting and recording, root cause analysis, corrective action development and implementation, preventive action development and implementation, and CAPA effectiveness verification.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305256</data>
  <data key="d6"></data>
</node>
<node id="Complaint Handling Procedure">
  <data key="d0">Complaint Handling Procedure</data>
  <data key="d1">method</data>
  <data key="d2">The Complaint Handling Procedure is a formal process that includes complaint receipt and recording, investigation and evaluation, handling and response, and complaint trend analysis.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305259</data>
  <data key="d6"></data>
</node>
<node id="Recall Procedure">
  <data key="d0">Recall Procedure</data>
  <data key="d1">method</data>
  <data key="d2">The Recall Procedure is a formal process that includes recall initiation and evaluation, implementation and monitoring, and closure and summary.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305259</data>
  <data key="d6"></data>
</node>
<node id="Self-Inspection Procedure">
  <data key="d0">Self-Inspection Procedure</data>
  <data key="d1">method</data>
  <data key="d2">The Self-Inspection Procedure is a formal process that includes self-inspection plan development, implementation, report preparation, and corrective and preventive action follow-up.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305259</data>
  <data key="d6"></data>
</node>
<node id="Clean Room">
  <data key="d0">Clean Room</data>
  <data key="d1">artifact</data>
  <data key="d2">A Clean Room (or clean area) is a controlled environment whose microbial and particulate levels must be monitored by the Quality Control Department.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305260</data>
  <data key="d6"></data>
</node>
<node id="Quality Control Laboratory">
  <data key="d0">Quality Control Laboratory</data>
  <data key="d1">organization</data>
  <data key="d2">The Quality Control Laboratory is the facility where testing and analysis are performed, requiring its own set of management procedures.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305260</data>
  <data key="d6"></data>
</node>
<node id="Internal Control Standards">
  <data key="d0">Internal Control Standards</data>
  <data key="d1">concept</data>
  <data key="d2">Internal Control Standards are specifications established and revised by the Quality Control Department for raw materials, intermediates, and finished products to ensure product quality.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305261</data>
  <data key="d6"></data>
</node>
<node id="Sampling Procedures">
  <data key="d0">Sampling Procedures</data>
  <data key="d1">method</data>
  <data key="d2">Sampling Procedures are operational guidelines developed by the Quality Control Department for the collection of representative samples from materials, intermediates, and finished products.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305262</data>
  <data key="d6"></data>
</node>
<node id="Testing Equipment">
  <data key="d0">Testing Equipment</data>
  <data key="d1">artifact</data>
  <data key="d2">Testing Equipment refers to instruments, reagents, reference standards (or reference substances), standard solutions, and culture media used in quality control testing, which require management procedures.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305262</data>
  <data key="d6"></data>
</node>
<node id="Raw Materials">
  <data key="d0">Raw Materials</data>
  <data key="d1">data</data>
  <data key="d2">Raw Materials are input substances used in pharmaceutical manufacturing that are subject to sampling, testing, retention, and quality stability evaluation by the Quality Control Department.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305264</data>
  <data key="d6"></data>
</node>
<node id="Intermediates">
  <data key="d0">Intermediates</data>
  <data key="d1">data</data>
  <data key="d2">Intermediates are in-process products during pharmaceutical manufacturing that are subject to sampling, testing, retention, and quality stability evaluation by the Quality Control Department.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305264</data>
  <data key="d6"></data>
</node>
<node id="Finished Products">
  <data key="d0">Finished Products</data>
  <data key="d1">data</data>
  <data key="d2">Finished Products are the final pharmaceutical products that are subject to sampling, testing, retention, quality stability evaluation, and testing report issuance by the Quality Control Department.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305265</data>
  <data key="d6"></data>
</node>
<node id="Testing Reports">
  <data key="d0">Testing Reports</data>
  <data key="d1">content</data>
  <data key="d2">Testing Reports are formal documents issued by the Quality Control Department after sampling, testing, and retention of raw materials, intermediates, and finished products.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305266</data>
  <data key="d6"></data>
</node>
<node id="Deviation Investigation">
  <data key="d0">Deviation Investigation</data>
  <data key="d1">method</data>
  <data key="d2">Deviation Investigation is a systematic process that includes deviation description, root cause analysis, impact assessment on product quality, corrective measures, and preventive measures.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305266</data>
  <data key="d6"></data>
</node>
<node id="Root Cause Analysis">
  <data key="d0">Root Cause Analysis</data>
  <data key="d1">method</data>
  <data key="d2">Root Cause Analysis is a systematic method used in deviation investigation and CAPA procedures to identify the fundamental cause of a non-conformance or deviation.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305266</data>
  <data key="d6"></data>
</node>
<node id="Corrective And Preventive Actions">
  <data key="d0">Corrective And Preventive Actions</data>
  <data key="d1">concept</data>
  <data key="d2">Corrective And Preventive Actions (CAPA) are measures developed and implemented to address identified non-conformances, deviations, and to prevent their recurrence, with effectiveness verification required.</data>
  <data key="d3">chunk-f02f1d47c5603a456144bcf4cd0849d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305267</data>
  <data key="d6"></data>
</node>
<node id="ICH Q10">
  <data key="d0">ICH Q10</data>
  <data key="d1">content</data>
  <data key="d2">ICH Q10 is a guideline that describes the Pharmaceutical Quality System (PQS) for pharmaceutical products, based on ICH Q8, ICH Q9, and itself.</data>
  <data key="d3">chunk-f5b35ed187d30c5517f660031690eb31</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305346</data>
  <data key="d6"></data>
</node>
<node id="ICH Q8">
  <data key="d0">ICH Q8</data>
  <data key="d1">content</data>
  <data key="d2">ICH Q8 is a guideline focused on pharmaceutical development, serving as one of the foundational references for ICH Q10.</data>
  <data key="d3">chunk-f5b35ed187d30c5517f660031690eb31</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305346</data>
  <data key="d6"></data>
</node>
<node id="ICH Q9">
  <data key="d0">ICH Q9</data>
  <data key="d1">content</data>
  <data key="d2">ICH Q9 is a guideline focused on quality risk management, serving as one of the foundational references for ICH Q10.&lt;SEP&gt;ICH Q9 is a pharmaceutical guideline that defines the systematic process of quality risk management for assessing, controlling, communicating, and reviewing quality risks throughout the product lifecycle.</data>
  <data key="d3">chunk-f5b35ed187d30c5517f660031690eb31&lt;SEP&gt;chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305424</data>
  <data key="d6"></data>
</node>
<node id="Pharmaceutical Quality System">
  <data key="d0">Pharmaceutical Quality System</data>
  <data key="d1">concept</data>
  <data key="d2">The Pharmaceutical Quality System (PQS) is a comprehensive framework that encompasses GMP requirements, quality risk management, knowledge management, and continuous improvement for ensuring pharmaceutical product quality.</data>
  <data key="d3">chunk-f5b35ed187d30c5517f660031690eb31</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305346</data>
  <data key="d6"></data>
</node>
<node id="Quality Risk Management">
  <data key="d0">Quality Risk Management</data>
  <data key="d1">method</data>
  <data key="d2">Quality Risk Management is a systematic approach to assessing, controlling, communicating, and reviewing risks to the quality of pharmaceutical products across the product lifecycle.&lt;SEP&gt;Quality Risk Management (QRM) is a systematic process for assessing, controlling, communicating, and reviewing quality risks of pharmaceutical products throughout the product lifecycle.</data>
  <data key="d3">chunk-f5b35ed187d30c5517f660031690eb31&lt;SEP&gt;chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305424</data>
  <data key="d6"></data>
</node>
<node id="Knowledge Management">
  <data key="d0">Knowledge Management</data>
  <data key="d1">method</data>
  <data key="d2">Knowledge Management is a systematic method for collecting, analyzing, updating, and transferring data and knowledge to improve pharmaceutical processes and products.</data>
  <data key="d3">chunk-f5b35ed187d30c5517f660031690eb31</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305347</data>
  <data key="d6"></data>
</node>
<node id="Process Performance and Product Quality Monitoring">
  <data key="d0">Process Performance and Product Quality Monitoring</data>
  <data key="d1">method</data>
  <data key="d2">Process Performance and Product Quality Monitoring is a system for establishing monitoring of process performance and product quality, conducting periodic process performance evaluations, and implementing product quality reviews.</data>
  <data key="d3">chunk-f5b35ed187d30c5517f660031690eb31</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305347</data>
  <data key="d6"></data>
</node>
<node id="CAPA">
  <data key="d0">CAPA</data>
  <data key="d1">method</data>
  <data key="d2">Corrective Actions and Preventive Actions (CAPA) is a system that uses investigation methods to determine root causes of deviations, takes measures to prevent recurrence, validates effectiveness, and integrates with the knowledge management system.</data>
  <data key="d3">chunk-f5b35ed187d30c5517f660031690eb31</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305349</data>
  <data key="d6"></data>
</node>
<node id="Change Management">
  <data key="d0">Change Management</data>
  <data key="d1">method</data>
  <data key="d2">Change Management is a system that evaluates the impact of changes on product quality, requires changes to be approved, ensures planned and documented implementation, and confirms that changes achieve expected objectives through post-change review.&lt;SEP&gt;Change management is an application area where quality risk management can be applied to evaluate and control risks associated with changes in pharmaceutical processes or systems.</data>
  <data key="d3">chunk-f5b35ed187d30c5517f660031690eb31&lt;SEP&gt;chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305436</data>
  <data key="d6"></data>
</node>
<node id="Continuous Improvement">
  <data key="d0">Continuous Improvement</data>
  <data key="d1">concept</data>
  <data key="d2">Continuous Improvement is a culture and approach that uses data-driven methods and periodically evaluates the effectiveness of improvement measures within the pharmaceutical quality system.</data>
  <data key="d3">chunk-f5b35ed187d30c5517f660031690eb31</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305349</data>
  <data key="d6"></data>
</node>
<node id="Senior Management">
  <data key="d0">Senior Management</data>
  <data key="d1">organization</data>
  <data key="d2">Senior Management holds ultimate responsibility for the Pharmaceutical Quality System, including establishing clear quality objectives, ensuring resource availability, establishing organizational structure, and ensuring employee understanding and implementation.</data>
  <data key="d3">chunk-f5b35ed187d30c5517f660031690eb31</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305350</data>
  <data key="d6"></data>
</node>
<node id="Periodic Review of PQS">
  <data key="d0">Periodic Review of PQS</data>
  <data key="d1">event</data>
  <data key="d2">Periodic Review of PQS is a scheduled evaluation of the effectiveness of the Pharmaceutical Quality System, covering process performance, product quality, and CAPA, with results used for continuous improvement.</data>
  <data key="d3">chunk-f5b35ed187d30c5517f660031690eb31</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305351</data>
  <data key="d6"></data>
</node>
<node id="Quality Objectives">
  <data key="d0">Quality Objectives</data>
  <data key="d1">concept</data>
  <data key="d2">Quality Objectives are clear targets established by Senior Management as part of their responsibility for the Pharmaceutical Quality System.</data>
  <data key="d3">chunk-f5b35ed187d30c5517f660031690eb31</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305351</data>
  <data key="d6"></data>
</node>
<node id="Root Cause Investigation">
  <data key="d0">Root Cause Investigation</data>
  <data key="d1">method</data>
  <data key="d2">Root Cause Investigation is a systematic method used by the CAPA system to determine the underlying causes of deviations and quality issues.</data>
  <data key="d3">chunk-f5b35ed187d30c5517f660031690eb31</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305353</data>
  <data key="d6"></data>
</node>
<node id="Product Quality">
  <data key="d0">Product Quality</data>
  <data key="d1">concept</data>
  <data key="d2">Product Quality refers to the overall quality characteristics of pharmaceutical products that must be monitored, maintained, and improved through the Pharmaceutical Quality System.</data>
  <data key="d3">chunk-f5b35ed187d30c5517f660031690eb31</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305353</data>
  <data key="d6"></data>
</node>
<node id="Product Quality Review">
  <data key="d0">Product Quality Review</data>
  <data key="d1">method</data>
  <data key="d2">Product Quality Review is a periodic evaluation implemented as part of the Process Performance and Product Quality Monitoring system to assess the quality of pharmaceutical products.</data>
  <data key="d3">chunk-f5b35ed187d30c5517f660031690eb31</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305355</data>
  <data key="d6"></data>
</node>
<node id="Process Performance Evaluation">
  <data key="d0">Process Performance Evaluation</data>
  <data key="d1">method</data>
  <data key="d2">Process Performance Evaluation is a periodic assessment conducted to monitor and evaluate the performance of pharmaceutical manufacturing processes.</data>
  <data key="d3">chunk-f5b35ed187d30c5517f660031690eb31</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305355</data>
  <data key="d6"></data>
</node>
<node id="Risk Assessment">
  <data key="d0">Risk Assessment</data>
  <data key="d1">method</data>
  <data key="d2">Risk assessment is a component of the quality risk management process that includes risk identification, risk analysis, and risk evaluation.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305424</data>
  <data key="d6"></data>
</node>
<node id="Risk Control">
  <data key="d0">Risk Control</data>
  <data key="d1">method</data>
  <data key="d2">Risk control is a component of the quality risk management process that includes risk reduction and risk acceptance.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305424</data>
  <data key="d6"></data>
</node>
<node id="Risk Review">
  <data key="d0">Risk Review</data>
  <data key="d1">method</data>
  <data key="d2">Risk review is a component of the quality risk management process that involves periodically reviewing risk management decisions.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305426</data>
  <data key="d6"></data>
</node>
<node id="Risk Identification">
  <data key="d0">Risk Identification</data>
  <data key="d1">method</data>
  <data key="d2">Risk identification is the first step of risk assessment, focused on identifying potential hazards and risks associated with those hazards.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305426</data>
  <data key="d6"></data>
</node>
<node id="Risk Analysis">
  <data key="d0">Risk Analysis</data>
  <data key="d1">method</data>
  <data key="d2">Risk analysis is the second step of risk assessment, involving estimation of identified risks through evaluation of their severity and probability of occurrence.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305426</data>
  <data key="d6"></data>
</node>
<node id="Risk Evaluation">
  <data key="d0">Risk Evaluation</data>
  <data key="d1">method</data>
  <data key="d2">Risk evaluation is the third step of risk assessment, involving comparison of identified and analyzed risks against given risk criteria.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305426</data>
  <data key="d6"></data>
</node>
<node id="Risk Reduction">
  <data key="d0">Risk Reduction</data>
  <data key="d1">method</data>
  <data key="d2">Risk reduction is a component of risk control that involves taking measures to reduce risk when it exceeds acceptable levels.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305429</data>
  <data key="d6"></data>
</node>
<node id="Risk Acceptance">
  <data key="d0">Risk Acceptance</data>
  <data key="d1">concept</data>
  <data key="d2">Risk acceptance is a component of risk control that involves deciding to accept the level of residual risk.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305429</data>
  <data key="d6"></data>
</node>
<node id="FMEA">
  <data key="d0">FMEA</data>
  <data key="d1">method</data>
  <data key="d2">Failure Mode and Effects Analysis (FMEA) is a commonly used quality risk management tool for evaluating potential failure modes and their effects.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305429</data>
  <data key="d6"></data>
</node>
<node id="FTA">
  <data key="d0">FTA</data>
  <data key="d1">method</data>
  <data key="d2">Fault Tree Analysis (FTA) is a commonly used quality risk management tool for identifying root causes of failures through logical tree diagrams.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305430</data>
  <data key="d6"></data>
</node>
<node id="HACCP">
  <data key="d0">HACCP</data>
  <data key="d1">method</data>
  <data key="d2">Hazard Analysis and Critical Control Points (HACCP) is a commonly used quality risk management tool for identifying hazards and establishing critical control points.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305430</data>
  <data key="d6"></data>
</node>
<node id="HAZOP">
  <data key="d0">HAZOP</data>
  <data key="d1">method</data>
  <data key="d2">Hazard and Operability Analysis (HAZOP) is a commonly used quality risk management tool for identifying hazards and operability problems.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305431</data>
  <data key="d6"></data>
</node>
<node id="PHA">
  <data key="d0">PHA</data>
  <data key="d1">method</data>
  <data key="d2">Preliminary Hazard Analysis (PHA) is a commonly used quality risk management tool for identifying potential hazards at an early stage.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305431</data>
  <data key="d6"></data>
</node>
<node id="Risk Ranking And Filtering">
  <data key="d0">Risk Ranking And Filtering</data>
  <data key="d1">method</data>
  <data key="d2">Risk ranking and filtering is a commonly used quality risk management tool for prioritizing risks based on defined criteria.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305434</data>
  <data key="d6"></data>
</node>
<node id="Production Process Control">
  <data key="d0">Production Process Control</data>
  <data key="d1">method</data>
  <data key="d2">Production process control is an application area where quality risk management can be applied to manage risks in pharmaceutical manufacturing processes.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305435</data>
  <data key="d6"></data>
</node>
<node id="Deviation Handling">
  <data key="d0">Deviation Handling</data>
  <data key="d1">method</data>
  <data key="d2">Deviation handling is an application area where quality risk management can be applied to assess and manage risks arising from deviations in pharmaceutical processes.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305436</data>
  <data key="d6"></data>
</node>
<node id="Supplier Management">
  <data key="d0">Supplier Management</data>
  <data key="d1">method</data>
  <data key="d2">Supplier management is an application area where quality risk management can be applied to evaluate and control risks related to suppliers of materials and services.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305436</data>
  <data key="d6"></data>
</node>
<node id="Facility And Equipment Design">
  <data key="d0">Facility And Equipment Design</data>
  <data key="d1">method</data>
  <data key="d2">Facility and equipment design is an application area where quality risk management can be applied to identify and mitigate risks in the design of pharmaceutical facilities and equipment.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305437</data>
  <data key="d6"></data>
</node>
<node id="Validation And Confirmation">
  <data key="d0">Validation And Confirmation</data>
  <data key="d1">method</data>
  <data key="d2">Validation and confirmation is an application area where quality risk management can be applied to ensure that processes and systems meet predetermined specifications and quality requirements.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305437</data>
  <data key="d6"></data>
</node>
<node id="Document Management">
  <data key="d0">Document Management</data>
  <data key="d1">method</data>
  <data key="d2">Document management is an application area where quality risk management can be applied to manage risks associated with pharmaceutical documentation and record-keeping.</data>
  <data key="d3">chunk-6ec2e5ac9373134e60f22a76aa5fcf8b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1778305438</data>
  <data key="d6"></data>
</node>
